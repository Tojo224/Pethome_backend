# ============================================================
# PETHOME BACKEND - .gitignore
# ============================================================

# ─── Variables de entorno y secretos ────────────────────────
.env
*.env
.env.local
.env.*.local
adminsdk.json
gcs-credentials.json
serviceAccountKey.json
firebase-adminsdk.json
*-firebase-adminsdk-*.json
*.json.secret
*.json
gcs-credentials.json
service-account*.json
# ─── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc

# ─── Entorno virtual ────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/

# ─── Django ─────────────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static_root/

# ─── Migraciones (opcional: algunos equipos sí las versión) ─
# Si tu equipo las comparte, elimina estas dos líneas:
*/migrations/*.py
!*/migrations/__init__.py

# ─── Testing y cobertura ────────────────────────────────────
.coverage
coverage.xml
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
test-results/

# ─── Build y distribución Python ────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ─── Editores e IDEs ────────────────────────────────────────
# VS Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.ipr
*.iws

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.#*

# ─── Sistema operativo ──────────────────────────────────────
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
.fuse_hidden*
.Trash-*

# ─── Otros ──────────────────────────────────────────────────
*.bak
*.tmp
*.orig
