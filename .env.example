# Copia este archivo como .env y completa los valores

# Database
DATABASE_URL=postgresql://USUARIO:CONTRASEÑA@HOST:5432/NOMBRE_BD

# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.onrender.com,*.onrender.com

# CORS - Agrega aquí el dominio de tu frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com,https://www.yourdomain.com

# Email (opcional para notificaciones)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
